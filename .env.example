# JForm - Variables de entorno
# Copiar a .env.local para desarrollo local

# Neon PostgreSQL (serverless)
DATABASE_URL=postgres://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb

# Resend (email delivery)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM="JForm <onboarding@resend.dev>"

# Origen permitido para CORS (opcional, default: https://jform.vercel.app)
# APP_ORIGIN=https://tudominio.com
